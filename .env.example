# Salesforce Connected App
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret
SALESFORCE_INSTANCE_URL=https://your-domain.my.salesforce.com
SALESFORCE_REDIRECT_URI=https://your-heroku-app.herokuapp.com/auth/callback

# Redis (Heroku Redis will set this automatically)
REDIS_URL=redis://localhost:6379

# Session encryption secret
SESSION_SECRET=generate-a-random-256-bit-secret-here

# Server port (Heroku sets this automatically)
PORT=3000

# Mock mode: set to "true" to use mock Salesforce data (no real SF connection needed)
USE_MOCK=false
